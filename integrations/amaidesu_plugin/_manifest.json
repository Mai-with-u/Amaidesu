{
  "manifest_version": 2,
  "id": "amaidesu.amaidesu-plugin",
  "name": "Amaidesu 动作控制与提示词覆盖插件",
  "version": "2.0.0",
  "description": "用于控制 Amaidesu 虚拟形象的动作和情绪，通过 MaiBot 的 LLM 决策系统自动判断触发时机，并提供提示词覆盖功能",
  "author": {
    "name": "Amaidesu",
    "url": "https://github.com/Mai-with-u/Amaidesu"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/Mai-with-u/Amaidesu",
    "homepage": "https://github.com/Mai-with-u/Amaidesu"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.0.0"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "capabilities": [
    "send.text",
    "send.amaidesu_react",
    "config.get"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": ["zh-CN"]
  },
  "dependencies": []
}